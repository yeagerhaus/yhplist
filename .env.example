# Spotify app client ID (public client, PKCE flow — no client secret needed)
# Create an app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:8888/callback as a Redirect URI on the app
SPOTIFY_CLIENT_ID=

# Plex server base URL
PLEX_URL=http://localhost:32400

# Plex API token (Settings -> find your account's X-Plex-Token, or see
# https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/)
PLEX_TOKEN=

# Music library section to match against (title or numeric ID).
# Optional if your Plex server only has one music library.
PLEX_MUSIC_SECTION=

# Fuzzy match similarity threshold, 0-100. Tracks scoring below this are
# logged as missing instead of added to the playlist.
MATCH_THRESHOLD=85

# Where the Spotify token cache and run logs are written
YHPLIST_STATE_PATH=.yhplist
